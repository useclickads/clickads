{
  "name": "novabuilder",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "bootstrap": "pnpm install",
    "db:setup": "pnpm --filter @novabuilder/api run db:setup"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.30.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "turbo": "^1.10.0",
    "typescript": "^5.6.0"
  }
}
