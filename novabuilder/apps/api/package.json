{
  "name": "@novabuilder/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "start": "node dist/main.js",
    "seed": "ts-node --transpile-only prisma/seed.ts",
    "migrate:dev": "npx prisma migrate dev --schema=prisma/schema.prisma --name init --url \"${DATABASE_URL:-postgresql://novabuilder:novabuilder@localhost:5432/novabuilder}\"",
    "db:setup": "pnpm run migrate:dev && pnpm run seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "10.3.2",
    "@nestjs/core": "10.3.2",
    "@nestjs/passport": "10.0.0",
    "@nestjs/platform-express": "10.3.2",
    "@nestjs/platform-socket.io": "^10.3.2",
    "@nestjs/websockets": "10.3.2",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@sentry/node": "^10.53.1",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "passport": "^0.6.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.0",
    "rate-limiter-flexible": "^2.3.9",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@nestjs/cli": "10.3.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/passport-google-oauth20": "^2.0.9",
    "@types/passport-jwt": "^3.0.10",
    "@types/speakeasy": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.1",
    "tsx": "^3.12.0",
    "typescript": "^5.6.0"
  }
}
