generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum AccountProvider {
  GOOGLE
  GITHUB
  EMAIL
}

enum RoleScope {
  GLOBAL
  PROJECT
  TEAM
}

// Core
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  avatarUrl    String?
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  sessions             Session[]
  accounts             Account[]
  projects             Project[]             @relation("UserProjects")
  roles                RoleAssignment[]
  teams                TeamMember[]
  rollbackLogs         RollbackLog[]
  publishHistories     PublishHistory[]
  presenceSessions     PresenceSession[]
  comments             Comment[]
  aigenerations        AIGeneration[]
  aimemories           AIMemory[]
  subscriptions        Subscription[]
  pluginInstallations  PluginInstallation[]
  marketplacePurchases MarketplacePurchase[]
  auditLogs            AuditLog[]
  securityLogs         SecurityLog[]
  apiKeys              ApiKey[]
  notifications        Notification[]

  @@index([email])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String          @id @default(uuid())
  provider          AccountProvider
  providerAccountId String
  userId            String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Role {
  id          String    @id @default(uuid())
  name        String
  scope       RoleScope @default(GLOBAL)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  assignments RoleAssignment[]

  @@index([name])
}

model Permission {
  id          String    @id @default(uuid())
  key         String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([key])
}

model RoleAssignment {
  id        String    @id @default(uuid())
  roleId    String
  userId    String
  projectId String?
  teamId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role    Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
}

model MagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// Projects and content
model Project {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  ownerId     String
  tenantId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner User @relation("UserProjects", fields: [ownerId], references: [id], onDelete: Cascade)

  pages               Page[]
  layouts             Layout[]
  components          Component[]
  blocks              Block[]
  versions            Version[]
  snapshots           Snapshot[]
  teams               Team[]
  roleAssignments     RoleAssignment[]
  rollbackLogs        RollbackLog[]
  cmscollections      CMSCollection[]
  folders             Folder[]
  assets              Asset[]
  domains             Domain[]
  deployments         Deployment[]
  publishHistories    PublishHistory[]
  collaborators       Collaborator[]
  presenceSessions    PresenceSession[]
  commentThreads      CommentThread[]
  aigenerations       AIGeneration[]
  aimemories          AIMemory[]
  analytics           Analytics[]
  heatmaps            Heatmap[]
  funnels             Funnel[]
  pluginInstallations PluginInstallation[]
  webhooks            Webhook[]
  integrations        Integration[]
  designTokens        DesignToken[]
  themeVersions       ThemeVersion[]
  usageMetrics        UsageMetric[]
  searchIndexes       SearchIndex[]
  formSubmissions     FormSubmission[]
  settings            ProjectSettings?

  @@index([ownerId])
  @@index([tenantId])
}

model Page {
  id        String    @id @default(uuid())
  projectId String
  title     String
  slug      String
  path      String
  content   Json?
  seo       Json?
  published Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  layouts Layout? @relation(fields: [id], references: [id])

  @@index([projectId])
  @@index([slug])
}

model Layout {
  id        String    @id @default(uuid())
  projectId String
  name      String
  json      Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages   Page[]

  @@index([projectId])
}

model Component {
  id        String    @id @default(uuid())
  projectId String
  name      String
  type      String
  props     Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Block {
  id        String    @id @default(uuid())
  projectId String
  name      String
  category  String
  schema    Json
  preview   String? // base64 thumbnail
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
}

model Version {
  id        String    @id @default(uuid())
  projectId String
  tag       String
  meta      Json
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots Snapshot[]

  @@index([projectId])
}

model Snapshot {
  id        String    @id @default(uuid())
  projectId String
  versionId String?
  data      Json
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version Version? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

model RollbackLog {
  id             String   @id @default(uuid())
  projectId      String
  fromSnapshotId String?
  toSnapshotId   String?
  userId         String?
  reason         String?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// CMS
model CMSCollection {
  id        String     @id @default(uuid())
  projectId String
  name      String
  slug      String
  fields    CMSField[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cmsentries CMSEntry[]

  @@unique([projectId, slug])
}

model CMSField {
  id           String    @id @default(uuid())
  collectionId String
  name         String
  type         String
  options      Json?
  validations  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  collection CMSCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CMSEntry {
  id           String    @id @default(uuid())
  collectionId String
  data         Json
  locale       String    @default("en")
  status       String    @default("draft")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  collection CMSCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
  @@index([locale])
}

// Assets
model Folder {
  id        String    @id @default(uuid())
  projectId String
  name      String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets  Asset[]

  @@index([projectId])
}

model Asset {
  id        String    @id @default(uuid())
  projectId String
  folderId  String?
  filename  String
  url       String
  size      Int?
  mimeType  String?
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([filename])
}

// Publishing
model Domain {
  id        String    @id @default(uuid())
  projectId String
  domain    String    @unique
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Deployment {
  id        String    @id @default(uuid())
  projectId String
  url       String
  status    String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publishHistories PublishHistory[]

  @@index([projectId])
}

model PublishHistory {
  id           String   @id @default(uuid())
  projectId    String
  deploymentId String?
  userId       String?
  note         String?
  createdAt    DateTime @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployment Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// Collaboration
model Team {
  id        String    @id @default(uuid())
  projectId String?
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members         TeamMember[]
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleAssignments RoleAssignment[]

  @@index([projectId])
}

model TeamMember {
  id        String    @id @default(uuid())
  teamId    String
  userId    String
  role      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([userId])
}

model Collaborator {
  id        String    @id @default(uuid())
  projectId String
  email     String
  role      String
  invitedBy String?
  accepted  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([email])
}

model PresenceSession {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model CommentThread {
  id        String    @id @default(uuid())
  projectId String
  elementId String
  resolved  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([elementId])
}

model Comment {
  id        String    @id @default(uuid())
  threadId  String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  thread   CommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?      @relation("CommentParent", fields: [parentId], references: [id], onDelete: SetNull)
  comments Comment[]     @relation("CommentParent")

  @@index([threadId])
  @@index([userId])
}

// AI
model AIGeneration {
  id        String   @id @default(uuid())
  projectId String?
  userId    String?
  prompt    String
  response  Json
  provider  String
  cost      Float?
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
}

model AIMemory {
  id        String   @id @default(uuid())
  userId    String?
  projectId String?
  key       String
  value     Json
  vector    Json? // store embedding as JSON array or use vector extension
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([key])
}

// Analytics
model Analytics {
  id        String   @id @default(uuid())
  projectId String
  createdAt DateTime @default(now())

  events  AnalyticsEvent[]
  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  analyticsId String
  type        String
  payload     Json
  createdAt   DateTime @default(now())

  analytics Analytics @relation(fields: [analyticsId], references: [id], onDelete: Cascade)

  @@index([analyticsId])
  @@index([type])
}

model Heatmap {
  id        String   @id @default(uuid())
  projectId String
  data      Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Funnel {
  id        String   @id @default(uuid())
  projectId String
  steps     Json
  results   Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Billing
model Subscription {
  id               String    @id @default(uuid())
  userId           String
  plan             String
  status           String
  startedAt        DateTime
  endedAt          DateTime?
  stripeCustomerId String?
  stripeSubId      String?
  createdAt        DateTime  @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingInvoices BillingInvoice[]
  billingUsages   BillingUsage[]

  @@index([userId])
}

model BillingInvoice {
  id             String    @id @default(uuid())
  subscriptionId String?
  amount         Float
  currency       String
  issuedAt       DateTime
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
}

model BillingUsage {
  id             String   @id @default(uuid())
  subscriptionId String?
  metric         String
  quantity       Float
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([metric])
}

// Platform / marketplace
model Plugin {
  id          String   @id @default(uuid())
  name        String
  version     String
  publisherId String?
  manifest    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  installations    PluginInstallation[]
  marketplaceItems MarketplaceItem[]

  @@index([name])
}

model PluginInstallation {
  id        String   @id @default(uuid())
  pluginId  String
  projectId String?
  userId    String?
  config    Json?
  createdAt DateTime @default(now())

  plugin  Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([pluginId])
}

model MarketplaceItem {
  id        String   @id @default(uuid())
  pluginId  String
  price     Float
  createdAt DateTime @default(now())

  plugin               Plugin                @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  marketplacePurchases MarketplacePurchase[]

  @@index([pluginId])
}

model MarketplacePurchase {
  id        String   @id @default(uuid())
  itemId    String
  buyerId   String
  createdAt DateTime @default(now())

  item  MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  buyer User            @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([buyerId])
}

model FeatureFlag {
  id        String   @id @default(uuid())
  key       String   @unique
  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Experiment {
  id        String   @id @default(uuid())
  key       String
  config    Json
  createdAt DateTime @default(now())

  @@index([key])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  meta       Json?
  ip         String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([resource])
}

model SecurityLog {
  id        String   @id @default(uuid())
  userId    String?
  event     String
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  ownerId   String?
  scopes    String[]
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
}

model Webhook {
  id        String   @id @default(uuid())
  projectId String
  url       String
  events    String[]
  secret    String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Integration {
  id        String   @id @default(uuid())
  projectId String
  provider  String
  config    Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  payload   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DesignToken {
  id        String   @id @default(uuid())
  projectId String
  key       String
  value     Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ThemeVersion {
  id        String   @id @default(uuid())
  projectId String
  tokens    Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model TenantSetting {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([key])
}

model UsageMetric {
  id         String   @id @default(uuid())
  projectId  String?
  key        String
  value      Float
  recordedAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([key])
}

model SearchIndex {
  id        String   @id @default(uuid())
  projectId String
  name      String
  config    Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model FormSubmission {
  id        String   @id @default(uuid())
  projectId String
  pageId    String?
  formName  String
  data      Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([formName])
}

model ProjectSettings {
  id              String   @id @default(uuid())
  projectId       String   @unique
  globalHeader    Json?
  globalFooter    Json?
  headScripts     String?
  bodyScripts     String?
  favicon         String?
  socialImage     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
